# --- Base de donnees ---
# SQLite par defaut (aucune configuration). Pour PostgreSQL :
# DATABASE_URL=postgresql://user:pass@localhost/pim
DATABASE_URL=sqlite:///./pim.db

# --- Ingestion par IA de vision (Google Gemini, tier gratuit, sans carte) ---
# Cle gratuite a creer sur https://aistudio.google.com/apikey
GEMINI_API_KEY=colle_ta_cle_ici
GEMINI_MODEL=gemini-2.5-flash
